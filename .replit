modules = ["nodejs-20"]
[agent]
expertMode = true
run = "npm start"
stack = "BEST_EFFORT_FALLBACK"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80
[interpreter]
command = ["npx", "--yes", "serve", "."]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

run = "node server.js"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[nix]
channel = "stable-25_05"
